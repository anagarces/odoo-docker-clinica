<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VISTA LISTA -->
    <record id="view_clinica_ausencia_list" model="ir.ui.view">
        <field name="name">clinica.ausencia.list</field>
        <field name="model">clinica.ausencia</field>
        <field name="arch" type="xml">
            <list string="Ausencias"
                decoration-warning="estado == 'pendiente'"
                decoration-success="estado == 'confirmada'"
                decoration-muted="estado == 'cancelada'"
            >
                <field name="medico_id"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="motivo"/>
                <field name="estado"/>
            </list>
        </field>
    </record>

    <!-- VISTA FORMULARIO -->
    <record id="view_clinica_ausencia_form" model="ir.ui.view">
        <field name="name">clinica.ausencia.form</field>
        <field name="model">clinica.ausencia</field>
        <field name="arch" type="xml">
            <form string="Ausencia de Médico">
                <header>
                    <button
                        name="action_confirmar"
                        string="Confirmar Ausencia"
                        type="object"
                        class="btn-primary"
                        invisible="estado != 'pendiente'"
                    />
                    <button
                        name="action_cancelar"
                        string="Cancelar Ausencia"
                        type="object"
                        class="btn-danger"
                        invisible="estado == 'cancelada'"
                    />
                    <field name="estado" widget="statusbar"
                        statusbar_visible="pendiente,confirmada,cancelada"
                    />
                </header>
                <sheet>
                    <group>
                        <group string="Médico y Motivo">
                            <field name="medico_id"
                                readonly="estado != 'pendiente'"
                            />
                            <field name="motivo"
                                readonly="estado != 'pendiente'"
                            />
                        </group>
                        <group string="Período">
                            <field name="fecha_inicio"
                                readonly="estado != 'pendiente'"
                            />
                            <field name="fecha_fin"
                                readonly="estado != 'pendiente'"
                            />
                        </group>
                    </group>
                    <group string="Notas">
                        <field name="notas" nolabel="1"
                            readonly="estado != 'pendiente'"
                        />
                    </group>
                    <notebook>
                        <page string="Slots Bloqueados">
                            <field name="slot_ids">
                                <list>
                                    <field name="fecha_inicio"/>
                                    <field name="fecha_fin"/>
                                    <field name="estado"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACCIÓN -->
    <record id="action_clinica_ausencia" model="ir.actions.act_window">
        <field name="name">Ausencias de Médicos</field>
        <field name="res_model">clinica.ausencia</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>