<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VISTA LISTA -->
    <record id="view_clinica_medico_list" model="ir.ui.view">
        <field name="name">clinica.medico.list</field>
        <field name="model">clinica.medico</field>
        <field name="arch" type="xml">
            <tree string="Médicos">
                <field name="name"/>
                <field name="especialidad"/>
                <field name="num_colegiado"/>
                <field name="duracion_cita"/>
            </tree>
        </field>
    </record>

    <!-- VISTA FORMULARIO -->
    <record id="view_clinica_medico_form" model="ir.ui.view">
        <field name="name">clinica.medico.form</field>
        <field name="model">clinica.medico</field>
        <field name="arch" type="xml">
            <form string="Médico">
                <header>
                    <button
                        name="action_generar_slots"
                        string="Generar Slots (4 semanas)"
                        type="object"
                        class="btn-primary"
                    />
                </header>
                <sheet>
                    <group string="Datos del Médico">
                        <group>
                            <field name="name"/>
                            <field name="especialidad"/>
                            <field name="tz"/>
                        </group>
                        <group>
                            <field name="num_colegiado"/>
                            <field name="duracion_cita"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Horarios de Atención">
                            <field name="horario_ids">
                                <tree editable="bottom">
                                    <field name="dia_semana"/>
                                    <field name="hora_inicio"
                                        widget="float_time"/>
                                    <field name="hora_fin"
                                        widget="float_time"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Slots Generados">
                            <field name="slot_ids">
                                <tree>
                                    <field name="fecha_inicio"/>
                                    <field name="fecha_fin"/>
                                    <field name="estado"
                                        decoration-success="estado == 'libre'"
                                        decoration-danger="estado == 'ocupado'"
                                        decoration-muted="estado == 'bloqueado'"
                                    />
                                    <field name="cita_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Ausencias">
                            <field name="ausencia_ids">
                                <tree>
                                    <field name="fecha_inicio"/>
                                    <field name="fecha_fin"/>
                                    <field name="motivo"/>
                                    <field name="estado"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_clinica_medico" model="ir.actions.act_window">
        <field name="name">Médicos</field>
        <field name="res_model">clinica.medico</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>