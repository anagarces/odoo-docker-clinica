<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VISTA LISTA -->
    <record id="view_clinica_slot_list" model="ir.ui.view">
        <field name="name">clinica.slot.list</field>
        <field name="model">clinica.slot</field>
        <field name="arch" type="xml">
            <list string="Slots"
                decoration-success="estado == 'libre'"
                decoration-danger="estado == 'ocupado'"
                decoration-muted="estado == 'bloqueado'"
            >
                <field name="medico_id"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="estado"/>
                <field name="cita_id"/>
                <field name="ausencia_id"/>
            </list>
        </field>
    </record>

    <!-- VISTA FORMULARIO -->
    <record id="view_clinica_slot_form" model="ir.ui.view">
        <field name="name">clinica.slot.form</field>
        <field name="model">clinica.slot</field>
        <field name="arch" type="xml">
            <form string="Slot">
                <sheet>
                    <group>
                        <group string="Datos del Slot">
                            <field name="medico_id"/>
                            <field name="fecha_inicio"/>
                            <field name="fecha_fin"/>
                            <field name="estado"/>
                        </group>
                        <group string="Asignación">
                            <field name="cita_id"/>
                            <field name="ausencia_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- VISTA BÚSQUEDA con filtros útiles -->
    <record id="view_clinica_slot_search" model="ir.ui.view">
        <field name="name">clinica.slot.search</field>
        <field name="model">clinica.slot</field>
        <field name="arch" type="xml">
            <search string="Buscar Slots">
                <field name="medico_id"/>
                <field name="fecha_inicio"/>
                <filter
                    string="Libres"
                    name="filter_libres"
                    domain="[('estado', '=', 'libre')]"
                />
                <filter
                    string="Ocupados"
                    name="filter_ocupados"
                    domain="[('estado', '=', 'ocupado')]"
                />
                <filter
                    string="Bloqueados"
                    name="filter_bloqueados"
                    domain="[('estado', '=', 'bloqueado')]"
                />
                <separator/>
                <filter
                    string="Hoy"
                    name="filter_hoy"
                    domain="[
                        ('fecha_inicio', '&gt;=', datetime.datetime.now().strftime('%Y-%m-%d 00:00:00')),
                        ('fecha_inicio', '&lt;=', datetime.datetime.now().strftime('%Y-%m-%d 23:59:59'))
                    ]"
                />
                <group expand="0" string="Agrupar por">
                    <filter
                        string="Médico"
                        name="group_medico"
                        context="{'group_by': 'medico_id'}"
                    />
                    <filter
                        string="Estado"
                        name="group_estado"
                        context="{'group_by': 'estado'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <!-- ACCIÓN -->
    <record id="action_clinica_slot" model="ir.actions.act_window">
        <field name="name">Planificación de Slots</field>
        <field name="res_model">clinica.slot</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_clinica_slot_search"/>
        <field name="context">{'search_default_filter_libres': 1}</field>
    </record>

</odoo>