<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_clinica_paciente_list" model="ir.ui.view">
        <field name="name">clinica.paciente.list</field>
        <field name="model">clinica.paciente</field>
        <field name="arch" type="xml">
            <tree string="Pacientes">
                <field name="name"/>
                <field name="fecha_nacimiento"/>
                <field name="tipo_sangre"/>
                <field name="telefono"/>
                <field name="es_alergico"/>
            </tree>
        </field>
    </record>

    <record id="view_clinica_paciente_form" model="ir.ui.view">
        <field name="name">clinica.paciente.form</field>
        <field name="model">clinica.paciente</field>
        <field name="arch" type="xml">
            <form string="Paciente">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="fecha_nacimiento"/>
                            <field name="tipo_sangre"/>
                        </group>
                        <group>
                            <field name="telefono"/>
                            <field name="email"/>
                            <field name="es_alergico"/>
                            <field name="detalles_alergias"
                                invisible="not es_alergico"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Historial de Citas">
                            <field name="cita_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="medico_id"/>
                                    <field name="fecha_inicio"/>
                                    <field name="estado"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_clinica_paciente" model="ir.actions.act_window">
        <field name="name">Pacientes</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">clinica.paciente</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primer paciente
            </p>
        </field>
    </record>

</odoo>