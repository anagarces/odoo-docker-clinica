<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_clinica_category" model="ir.module.category">
        <field name="name">Clínica</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_clinica_admin" model="res.groups">
        <field name="name">Administrador</field>
        <field name="category_id" ref="module_clinica_category"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_clinica_recepcionista" model="res.groups">
        <field name="name">Recepcionista</field>
        <field name="category_id" ref="module_clinica_category"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

</odoo>